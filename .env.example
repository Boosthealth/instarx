# Convert.com Full-Stack SDK — server-side A/B testing
# -----------------------------------------------------
# Copy this file to `.env.local` and fill in the values from your Convert
# dashboard (Project → Settings → SDK / API keys).
#
# Until CONVERT_SDK_KEY is set, the app renders the CONTROL experience
# everywhere (the integration degrades gracefully — see app/lib/convert.ts).
#
# This must be a Full-Stack SDK key (Configuration → SDK Config & Keys), NOT a
# REST API application key. An unauthenticated key works on its own (leave the
# secret blank). An Authenticated key also has a secret — more secure for
# server-side use; set CONVERT_SDK_KEY_SECRET and it's sent automatically.
# Either way, keep these server-side only — never expose them to the browser.

CONVERT_SDK_KEY=
CONVERT_SDK_KEY_SECRET=    # optional — only for an Authenticated key

# "production" or "staging" — must match the environment your experiences are
# live in within Convert. Defaults to "production" if unset.
CONVERT_ENVIRONMENT=production
